-- WezTerm custom shortcut reference (macOS).
--
-- Workspaces
-- Cmd+Shift+N          Create or switch workspace (prompt for name)
-- Cmd+Shift+P          Open workspace picker
-- Cmd+Opt+[            Previous workspace
-- Cmd+Opt+]            Next workspace
-- Cmd+Opt+LeftArrow    Previous workspace (alternate)
-- Cmd+Opt+RightArrow   Next workspace (alternate)
-- Cmd+Opt+M            Jump to "main" workspace
-- Cmd+Shift+Opt+W      Delete current workspace (moves windows to "main")
--
-- Tabs
-- Cmd+T                New tab
-- Cmd+Shift+O          Tab navigator
-- Cmd+W                Close current tab (with confirmation)
--
-- Panes
-- Cmd+Shift+[          Previous pane
-- Cmd+Shift+]          Next pane
-- Cmd+Ctrl+LeftArrow   Focus pane left
-- Cmd+Ctrl+RightArrow  Focus pane right
-- Cmd+Ctrl+UpArrow     Focus pane up
-- Cmd+Ctrl+DownArrow   Focus pane down
-- Cmd+Ctrl+P           Pane selector
-- Cmd+Shift+W          Close current pane (with confirmation)
--
-- Font size
-- Cmd++                Increase font size
-- Cmd+-                Decrease font size
-- Cmd+0                Reset font size

local wezterm = require 'wezterm'
local mux = wezterm.mux
local act = wezterm.action

local DEFAULT_WORKSPACE = "main"
local HOME_DIR = os.getenv("HOME") or ""

local LIGHT_BG = "#f4f4f4"
local LIGHT_BG_SOFT = "#ececec"
local LIGHT_FG = "#3e3e3e"
local LIGHT_MUTED = "#6a737d"
local LIGHT_ACCENT = "#2f6feb"
local LIGHT_SELECTION = "#c9def5"

-- Helpers
local function decode_uri_component(path)
  return (path:gsub("%%(%x%x)", function(hex)
    return string.char(tonumber(hex, 16))
  end))
end

local function cwd_uri_to_path(cwd_uri)
  if not cwd_uri then
    return nil
  end

  if type(cwd_uri) == "table" and cwd_uri.file_path then
    return cwd_uri.file_path
  end

  local uri = tostring(cwd_uri)
  if uri == "" then
    return nil
  end

  local path = uri
    :gsub("^file://[^/]*", "")
    :gsub("^file://", "")
  return decode_uri_component(path)
end

local function format_home_relative(path)
  if not path or path == "" then
    return nil
  end

  if HOME_DIR ~= "" then
    if path == HOME_DIR then
      return "~"
    end

    local home_prefix = HOME_DIR .. "/"
    if path:sub(1, #home_prefix) == home_prefix then
      return "~/" .. path:sub(#home_prefix + 1)
    end
  end

  return path
end

local function sorted_workspaces()
  local names = mux.get_workspace_names()
  table.sort(names, function(a, b)
    if a == DEFAULT_WORKSPACE then return true end
    if b == DEFAULT_WORKSPACE then return false end
    return a:lower() < b:lower()
  end)
  return names
end

local function switch_workspace_relative(window, pane, delta)
  local target_pane = window:active_pane() or pane
  if not target_pane then return end
  window:perform_action(act.SwitchWorkspaceRelative(delta), target_pane)
end

local function delete_active_workspace(window, pane)
  local current = window:active_workspace()
  if current == DEFAULT_WORKSPACE then
    window:toast_notification("WezTerm", "Cannot delete '" .. DEFAULT_WORKSPACE .. "' workspace", nil, 3000)
    return
  end

  local moved = 0
  for _, mux_window in ipairs(mux.all_windows()) do
    if mux_window:get_workspace() == current then
      mux_window:set_workspace(DEFAULT_WORKSPACE)
      moved = moved + 1
    end
  end

  local target_pane = window:active_pane() or pane
  if target_pane then
    window:perform_action(act.SwitchToWorkspace { name = DEFAULT_WORKSPACE }, target_pane)
  end

  window:toast_notification(
    "WezTerm",
    "Workspace '" .. current .. "' deleted (" .. tostring(moved) .. " window(s) moved to '" .. DEFAULT_WORKSPACE .. "')",
    nil,
    4000
  )
end

-- STATUS HANDLER (must be defined BEFORE return)
wezterm.on("update-status", function(window, pane)
  local ws = window:active_workspace()
  local names = sorted_workspaces()
  local list = #names > 0 and table.concat(names, "  ") or DEFAULT_WORKSPACE

  window:set_left_status(wezterm.format({
    { Attribute = { Intensity = "Bold" } },
    { Text = "  WS: " .. ws .. "  " },
  }))

  window:set_right_status(wezterm.format({
    { Text = " " .. list .. "   " },
    { Text = "  ⌘⇧P workspaces  ⌘⇧O tabs  ⌘W close tab  ⌘⇧⌥W delete ws  " },
  }))
end)

wezterm.on("format-tab-title", function(tab, _, _, _, _, max_width)
  local pane = tab.active_pane
  local cwd_path = pane and cwd_uri_to_path(pane.current_working_dir)
  local title = format_home_relative(cwd_path) or (pane and pane.title) or "shell"
  local padded = " " .. wezterm.truncate_right(title, math.max(max_width - 2, 1)) .. " "
  return padded
end)

return {
  default_workspace = DEFAULT_WORKSPACE,

  ---------------------------------------------------------------------------
  -- Look & Feel
  ---------------------------------------------------------------------------
  color_scheme = "Atelierheath (dark) (terminal.sexy)",
  font = wezterm.font("JetBrains Mono", { weight = "Bold" }),
  font_size = 12.0,
  line_height = 1.15,
  window_background_opacity = 1.0,
  text_background_opacity = 1.0,

  window_padding = {
    left = 10,
    right = 10,
    top = 8,
    bottom = 8,
  },

  default_cursor_style = "BlinkingBar",
  command_palette_bg_color = LIGHT_BG,
  command_palette_fg_color = LIGHT_FG,
  pane_select_bg_color = LIGHT_BG,
  pane_select_fg_color = LIGHT_FG,
  char_select_bg_color = LIGHT_BG,
  char_select_fg_color = LIGHT_FG,

  colors = {
    foreground = LIGHT_FG,
    background = "#fdfdfd",
    cursor_bg = LIGHT_ACCENT,
    cursor_fg = "#ffffff",
    cursor_border = LIGHT_ACCENT,
    selection_bg = LIGHT_SELECTION,
    selection_fg = LIGHT_FG,
    tab_bar = {
      background = LIGHT_BG,
      active_tab = {
        bg_color = "#ffffff",
        fg_color = LIGHT_FG,
        intensity = "Bold",
      },
      inactive_tab = {
        bg_color = LIGHT_BG_SOFT,
        fg_color = LIGHT_MUTED,
      },
      inactive_tab_hover = {
        bg_color = "#dfe6ef",
        fg_color = LIGHT_FG,
      },
      new_tab = {
        bg_color = LIGHT_BG,
        fg_color = LIGHT_FG,
      },
      new_tab_hover = {
        bg_color = "#dfe6ef",
        fg_color = LIGHT_FG,
      },
    },
  },

  ---------------------------------------------------------------------------
  -- Tabs at bottom
  ---------------------------------------------------------------------------
  enable_tab_bar = true,
  use_fancy_tab_bar = false,
  hide_tab_bar_if_only_one_tab = false,
  tab_bar_at_bottom = true,
  tab_max_width = 32,

  ---------------------------------------------------------------------------
  -- Keybindings
  ---------------------------------------------------------------------------
  keys = {
    -- Create / Switch workspace
    {
      key = "N",
      mods = "CMD|SHIFT",
      action = act.PromptInputLine {
        description = "Workspace name (create/switch)",
        action = wezterm.action_callback(function(window, pane, line)
          if line and #line > 0 then
            local target_pane = window:active_pane() or pane
            if not target_pane then return end
            window:perform_action(
              act.SwitchToWorkspace { name = line },
              target_pane
            )
          end
        end),
      },
    },

    -- Workspace picker
    {
      key = "P",
      mods = "CMD|SHIFT",
      action = act.ShowLauncherArgs {
        flags = "FUZZY|WORKSPACES",
        title = "Workspaces",
      },
    },

    -- Tabs navigator (version-safe themed switcher)
    {
      key = "O",
      mods = "CMD|SHIFT",
      action = act.ShowTabNavigator,
    },

    -- Workspace cycle
    {
      key = "[",
      mods = "CMD|OPT",
      action = wezterm.action_callback(function(window, pane)
        switch_workspace_relative(window, pane, -1)
      end),
    },
    {
      key = "]",
      mods = "CMD|OPT",
      action = wezterm.action_callback(function(window, pane)
        switch_workspace_relative(window, pane, 1)
      end),
    },
    {
      key = "LeftArrow",
      mods = "CMD|OPT",
      action = wezterm.action_callback(function(window, pane)
        switch_workspace_relative(window, pane, -1)
      end),
    },
    {
      key = "RightArrow",
      mods = "CMD|OPT",
      action = wezterm.action_callback(function(window, pane)
        switch_workspace_relative(window, pane, 1)
      end),
    },
    {
      key = "M",
      mods = "CMD|OPT",
      action = act.SwitchToWorkspace { name = DEFAULT_WORKSPACE },
    },

    -- Pane cycle (this was previously on workspace switching)
    { key = "[", mods = "CMD|SHIFT", action = act.ActivatePaneDirection "Prev" },
    { key = "]", mods = "CMD|SHIFT", action = act.ActivatePaneDirection "Next" },

    -- Pane directional navigation
    { key = "LeftArrow", mods = "CMD|CTRL", action = act.ActivatePaneDirection "Left" },
    { key = "RightArrow", mods = "CMD|CTRL", action = act.ActivatePaneDirection "Right" },
    { key = "UpArrow", mods = "CMD|CTRL", action = act.ActivatePaneDirection "Up" },
    { key = "DownArrow", mods = "CMD|CTRL", action = act.ActivatePaneDirection "Down" },
    { key = "p", mods = "CMD|CTRL", action = act.PaneSelect },

    -- New tab
    { key = "t", mods = "CMD", action = act.SpawnTab "CurrentPaneDomain" },
    { key = "w", mods = "CMD", action = act.CloseCurrentTab { confirm = true } },
    { key = "w", mods = "CMD|SHIFT", action = act.CloseCurrentPane { confirm = true } },
    {
      key = "W",
      mods = "CMD|SHIFT|OPT",
      action = wezterm.action_callback(function(window, pane)
        delete_active_workspace(window, pane)
      end),
    },

    -- Font resize
    { key = "+", mods = "CMD", action = act.IncreaseFontSize },
    { key = "-", mods = "CMD", action = act.DecreaseFontSize },
    { key = "0", mods = "CMD", action = act.ResetFontSize },
  },

  status_update_interval = 1000,
}
